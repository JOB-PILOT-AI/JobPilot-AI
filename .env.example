
NODE_ENV=production
PORT=10000
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/jobpilot
JWT_SECRET=replace-with-a-long-random-secret
CLIENT_URL=https://your-frontend-or-render-url
CORS_ORIGIN=https://your-frontend-or-render-url

VITE_API_URL=https://your-render-service.onrender.com
VITE_CLIENT_URL=https://your-frontend-or-render-url

GEMINI_API_KEY=replace_me
DISABLE_GEMINI=false
CADDIE_MODEL=gemini-2.5-flash
CAREER_MODEL=gemini-2.5-flash
INTERVIEW_MODEL=gemini-2.5-flash

RAZORPAY_KEY_ID=rzp_live_replace_me
RAZORPAY_KEY_SECRET=replace_me
RAZORPAY_PLAN_ID=plan_replace_me
RAZORPAY_WEBHOOK_SECRET=replace_with_dashboard_webhook_secret
RAZORPAY_TOTAL_COUNT=60
TRIAL_DAYS=30

RESEND_API_KEY=replace_me
EMAIL_FROM=JobPilot.AI <noreply@yourdomain.com>

GOOGLE_CLIENT_ID=replace_me
GOOGLE_CLIENT_SECRET=replace_me
GITHUB_CLIENT_ID=replace_me
GITHUB_CLIENT_SECRET=replace_me
